shape lTList = list of T

# sum requires T: Copy + Sum. min/max require T: Ord + Default.
# Intended for int and float lists.

fn T l_T_sum(lTList items)
	rust
		items.iter().copied().sum()

fn T l_T_min(lTList items)
	rust
		items.iter().cloned().min().unwrap_or_default()

fn T l_T_max(lTList items)
	rust
		items.iter().cloned().max().unwrap_or_default()
