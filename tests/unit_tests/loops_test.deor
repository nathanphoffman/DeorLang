fn int sum_to(int num)

	total as 0
	for idx in range(num)
		total = total + idx

	return total

fn int sum_range(int start, int stop)

	total as 0
	for idx in range(start, stop)
		total = total + idx

	return total

fn int count_down(int num)
	result as 0
	for idx in range(num)
		if idx < 2
			continue
		result = result + idx
	return result

fn void main()
	int total1 = sum_to(5)
	print(total1)
	int range_start = 3
	int range_end = 7
	int total2 = sum_range(range_start, range_end)
	print(total2)
	int total3 = count_down(5)
	print(total3)
	flag as true
	if not flag
		print("no")
	else
		print("yes")

# expect:
# 10
# 18
# 9
# yes
