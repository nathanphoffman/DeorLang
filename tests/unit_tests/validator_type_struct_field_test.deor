# validator_type_struct_field_test.deor
# A validator-typed struct field is Option<T> under the hood (see
# docs/validator_types.md#validator-types-in-structs). Exercises construction
# and destructuring of a struct with a validator-type field, then checks it
# with is valid.

type Squarefeet(int val)
	val > 0

struct Room
	string name
	Squarefeet area

struct House
	string address
	Room main_room

fn void main()
	name as "Office"
	Squarefeet area = 20
	Room room = (name, area)
	(area) in room
	if area is valid
		print("valid area")
	else
		print("should have been valid")

	# one level deeper — a struct nested inside a struct, itself carrying a
	# validator-type field, exercises resolve_type through two struct layers
	address as "123 Main St"
	main_room as room
	House house = (address, main_room)
	(main_room) in house
	(area) in main_room
	if area is valid
		print("valid nested area")
	else
		print("should have been valid nested")

# expect:
# valid area
# valid nested area
