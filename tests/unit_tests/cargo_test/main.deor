import "tests/unit_tests/cargo_test/lib/json.deor"

fn void main()
	string name_key = "name"
	string name_val = "Alice"
	string user = json_make(name_key, name_val)

	string city_key = "city"
	string city_val = "Portland"
	user = json_set(user, city_key, city_val)

	string lang_key = "lang"
	string lang_val = "Deor"
	user = json_set(user, lang_key, lang_val)

	print(user)

	string name = json_get(user, name_key)
	string city = json_get(user, city_key)
	string lang = json_get(user, lang_key)
	print(name)
	print(city)
	print(lang)
