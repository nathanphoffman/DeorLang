# string_concat_mixed_test.deor
# Exercises check_mixed_string_concat: a '+' chain cannot mix a string-typed
# operand with a numeric (int/float) one, in either order — the transpiler
# should catch this itself instead of letting it fail as an opaque rustc
# type-mismatch error.

fn void test_string_plus_int()
	int count = 5
	string bad = "count: " + count
	print(bad)

fn void test_int_plus_string()
	int count = 5
	string bad2 = count + "count: "
	print(bad2)

fn void test_string_plus_float()
	float ratio = 1.5
	string bad3 = "ratio: " + ratio
	print(bad3)

fn void main()
	print("should never reach here")

# expect-error:
# line 9: variable '+' - cannot mix a string and a number in a '+' chain
# line 14: variable '+' - cannot mix a string and a number in a '+' chain
# line 19: variable '+' - cannot mix a string and a number in a '+' chain
