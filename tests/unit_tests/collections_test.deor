import "lib/string.deor"

shape intList = list of int
shape wordList = list of string

fn int sum_list(intList nums)
	total as 0
	int cnt = len(nums)
	for idx in range(cnt)
		int val = nums at idx
		total = total + val
	return total

fn string join_two(string word_a, string word_b)
	return word_a + " " + word_b

fn void main()
	intList scores = [10, 20, 30]
	int cnt = len(scores)
	print(cnt)

	int first = scores at 0
	print(first)

	scores at 0 = 99
	int updated = scores at 0
	print(updated)

	int total = sum_list(scores)
	print(total)

	scores at end = 40
	int new_len = len(scores)
	print(new_len)

	scores remove at 0
	int after_remove = len(scores)
	print(after_remove)

	string hello = "hello"
	string world = "world"
	string msg = join_two(hello, world)
	print(msg)

	string line = "fn " + "main" + "()"
	print(line)

	wordList words = ["foo", "bar", "baz"]
	string word = words at 1
	print(word)

	string needle = "a"
	bool found = s_contains(word, needle)
	print(found)

	string upper_word = s_to_upper(word)
	print(upper_word)

# expect:
# 3
# 10
# 99
# 149
# 4
# 3
# hello world
# fn main()
# bar
# true
