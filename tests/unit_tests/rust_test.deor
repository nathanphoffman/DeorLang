fn int add_raw(int num_a, int num_b)
	rust
		num_a + num_b

fn string repeat_str(string text, int count)
	rust
		text.repeat(count as usize)

fn void main()
	int val_a = 3
	int val_b = 4
	int sum = add_raw(val_a, val_b)
	print(sum)
	string prefix = "ab"
	int times = 3
	string repeated = repeat_str(prefix, times)
	print(repeated)

# expect:
# 7
# ababab
