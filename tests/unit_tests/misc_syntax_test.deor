# misc_syntax_test.deor
# Exercises a grab-bag of remaining validator rules: returning 'empty' or
# 'none' from a function, a bad 'name ident literal' statement shape, an
# invalid raw character (including '!', banned because Deor has no '!='
# operator — 'is not' is required), and 'valid' used somewhere other than
# after 'is'.

fn int test_return_empty()
	return empty

fn int test_return_none()
	return none

fn void test_bad_stmt()
	string greeting "hello"

fn void test_invalid_char()
	int val_a = 5 & 3
	print(val_a)

fn void test_invalid_not_equal()
	int val_b = 5
	if val_b != 5
		print("bad")

fn void test_valid_misuse()
	bool result = valid

fn void main()
	print("should never reach here")

# expect-error:
# line 9: fn 'empty' - cannot return 'empty'
# line 12: fn 'none' - none is not a Deor keyword
# line 15: variable 'string' - literal cannot follow 'name ident'
# line 18: identifier '&' - character is not valid in Deor
# line 23: identifier '!' - character is not valid in Deor
# line 27: variable 'valid' - 'valid' can only appear after 'is' or 'is not'
