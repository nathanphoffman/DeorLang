# duplicate_decl_same_file_test.deor
# Exercises dedup.deor's duplicate-declaration check for two decls in the same file, with
# ENFORCE_UNIQUE_FILE_DECLARATIONS opted in via the pragma at the top of main() — a
# distinct error path from the token validator (fires during import-merging, immediate
# exit(1), no accumulation with other errors). Without the pragma this is silently
# tolerated instead — see duplicate_decl_default_loose_test.deor.

struct Player
	string name
	int score

struct Player
	string label

fn void main()
	ENFORCE_UNIQUE_FILE_DECLARATIONS
	print("unreachable")

# expect-error:
# duplicate declaration 'Player' — already declared in tests/unit_tests/duplicate_decl_same_file_test.deor
