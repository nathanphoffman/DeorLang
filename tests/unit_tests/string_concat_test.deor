# string_concat_test.deor
# Regression tests for `+` string-concat chains: chains where the literal that
# marks the chain as concatenation (rather than arithmetic) isn't the first
# operand, chains of varying length and literal position, and chains built
# directly inline (call arg / return / as-binding) rather than pre-bound to a
# `string` variable first.
#
# Every operand — leading or not — is only ever borrowed (`.as_str()`) into the
# `[...].concat()` call, never cloned or moved, so the source variable stays
# usable after the chain (see `reused_lead_var` below).

fn string glue(string aaa, string bbb)
	return aaa + bbb + "!"

fn void main()
	prefix as "pre-"
	content as "mid"

	# literal only at the end
	string chained = prefix + content + "!"
	print(chained)

	aaa as "a"
	bbb as "b"
	string three_deep = aaa + bbb + "-end"
	print(three_deep)

	# all literals
	string all_literals = "fn " + "main" + "()"
	print(all_literals)

	# literal only at the start
	ccc as "c"
	ddd as "d"
	string lead_literal = "Result: " + ccc + ddd
	print(lead_literal)

	# literal only in the middle
	eee as "e"
	fff as "f"
	string mid_literal = eee + "-" + fff
	print(mid_literal)

	# two operands, no third
	ggg as "g"
	string two_op = "Hi, " + ggg
	print(two_op)

	# four-operand chain
	hhh as "h"
	iii as "i"
	jjj as "j"
	string four_op = hhh + iii + jjj + "-end"
	print(four_op)

	# empty-string literal in the chain
	kkk as "k"
	string with_empty = "" + kkk + "!"
	print(with_empty)

	# chain built directly inline as a call argument, not pre-bound to a variable
	lll as "l-"
	mmm as "m"
	print(lll + mmm + "!")

	# chain built directly in a `name as expr` binding
	xxx as "pre-" + "mid" + "end"
	print(xxx)

	# chain returned directly from a function
	nnn as "n"
	ooo as "o"
	string returned = glue(nnn, ooo)
	print(returned)

	# call result used as the leading operand of a further chain
	ppp as "p"
	qqq as "q"
	string result_lead = glue(ppp, qqq) + " done"
	print(result_lead)

	# leading operand is a bare variable — must be cloned, not moved, so it's
	# still usable after the chain
	rrr as "r"
	string reused_lead_var = rrr + "-tail"
	print(reused_lead_var)
	print(rrr)

# expect:
# pre-mid!
# ab-end
# fn main()
# Result: cd
# e-f
# Hi, g
# hij-end
# k!
# l-m!
# pre-midend
# no!
# pq! done
# r-tail
# r
