{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Deor",
  "scopeName": "source.deor",
  "fileTypes": [
    "deor"
  ],
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#struct-definition"
    },
    {
      "include": "#type-definition"
    },
    {
      "include": "#enum-definition"
    },
    {
      "include": "#shape-definition"
    },
    {
      "include": "#keyword-fn"
    },
    {
      "include": "#keywords-storage"
    },
    {
      "include": "#keywords-control"
    },
    {
      "include": "#keywords-other"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#number"
    },
    {
      "include": "#shape-name"
    },
    {
      "include": "#user-type"
    },
    {
      "include": "#macro-bang"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#banned-operators"
    },
    {
      "include": "#operator"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.deor",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.deor",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "variable.other.interpolated.deor",
          "match": "\\{[a-z_][a-z0-9_]*\\}"
        },
        {
          "name": "constant.character.escape.deor",
          "match": "\\\\."
        }
      ]
    },
    "macro-bang": {
      "name": "entity.name.function.deor",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(!)"
    },
    "struct-definition": {
      "match": "\\b(struct[+*]?)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.deor"
        },
        "2": {
          "name": "entity.name.type.deor"
        }
      }
    },
    "type-definition": {
      "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.deor"
        },
        "2": {
          "name": "entity.name.type.deor"
        }
      }
    },
    "enum-definition": {
      "match": "\\b(enum)\\s+([a-z][a-z0-9]*[A-Z][a-zA-Z0-9]*)",
      "captures": {
        "1": {
          "name": "storage.type.deor"
        },
        "2": {
          "name": "entity.name.type.deor"
        }
      }
    },
    "shape-definition": {
      "match": "\\b(shape)\\s+([a-z][a-z0-9]*[A-Z][a-zA-Z0-9]*)",
      "captures": {
        "1": {
          "name": "storage.type.deor"
        },
        "2": {
          "name": "entity.name.type.deor"
        }
      }
    },
    "keyword-fn": {
      "name": "storage.type.function.deor",
      "match": "\\bfn\\b"
    },
    "keywords-storage": {
      "name": "storage.modifier.deor",
      "match": "\\b(const|private|raw)\\b"
    },
    "keywords-control": {
      "name": "keyword.control.deor",
      "match": "\\b(import|if|else|for|return|break|continue|crash|using|move|block)\\b"
    },
    "keywords-other": {
      "name": "keyword.other.deor",
      "match": "\\b(as|in|with|is|and|or|not|avow|of|to|where|rust|end|remove|at)\\b"
    },
    "builtin-types": {
      "name": "support.type.deor",
      "match": "\\b(int|float|bool|string|bytes|list|func|void|macro|unsafe_macro|macro_run|raw)\\b"
    },
    "constants": {
      "name": "constant.language.deor",
      "match": "\\b(true|false|valid|empty)\\b"
    },
    "number": {
      "name": "constant.numeric.deor",
      "match": "\\b\\d[\\d_]*(\\.[\\d_]+)?\\b"
    },
    "shape-name": {
      "name": "entity.name.type.deor",
      "match": "\\b[a-z][a-z0-9]*[A-Z][a-zA-Z0-9]*\\b"
    },
    "user-type": {
      "name": "entity.name.type.deor",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "function-call": {
      "name": "entity.name.function.deor",
      "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()"
    },
    "banned-operators": {
      "name": "invalid.illegal.deor",
      "match": "==|!=|&&|\\|\\|"
    },
    "operator": {
      "name": "keyword.operator.deor",
      "match": "\\+=|-=|\\*=|/=|%=|<=|>=|[+\\-*/%<>]|(?<![=!<>+\\-*/%])=(?![=])"
    }
  }
}