{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Deor",
  "scopeName": "source.deor",
  "fileTypes": ["deor"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#annotation" },
    { "include": "#string" },
    { "include": "#struct-definition" },
    { "include": "#type-definition" },
    { "include": "#keyword-fn" },
    { "include": "#keywords-storage" },
    { "include": "#keywords-control" },
    { "include": "#keywords-other" },
    { "include": "#mutation-verbs" },
    { "include": "#list-type" },
    { "include": "#builtin-types" },
    { "include": "#constants" },
    { "include": "#number" },
    { "include": "#user-type" },
    { "include": "#function-call" },
    { "include": "#banned-operators" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.deor",
      "match": "#.*$"
    },
    "annotation": {
      "name": "storage.modifier.deor",
      "match": "\\[(test|deprecated|pure|main|using[^\\]]*|shape[^\\]]*)\\]"
    },
    "string": {
      "name": "string.quoted.double.deor",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "variable.other.interpolated.deor", "match": "\\{[a-z_][a-z0-9_]*\\}" },
        { "name": "constant.character.escape.deor", "match": "\\\\." }
      ]
    },
    "struct-definition": {
      "match": "\\b(struct[+*]?)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.deor" },
        "2": { "name": "entity.name.type.deor" }
      }
    },
    "type-definition": {
      "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.deor" },
        "2": { "name": "entity.name.type.deor" }
      }
    },
    "keyword-fn": {
      "name": "storage.type.function.deor",
      "match": "\\bfn\\b"
    },
    "keywords-storage": {
      "name": "storage.modifier.deor",
      "match": "\\b(const|private)\\b"
    },
    "keywords-control": {
      "name": "keyword.control.deor",
      "match": "\\b(if|else|for|return|break|continue|throw)\\b"
    },
    "keywords-other": {
      "name": "keyword.other.deor",
      "match": "\\b(as|in|with|is|and|or|not|avow|using|rust|deps)\\b"
    },
    "mutation-verbs": {
      "name": "keyword.operator.mutation.deor",
      "match": "\\b(insert|remove|at)\\b"
    },
    "list-type": {
      "match": "\\b(list)(<[A-Za-z0-9_,\\s]*>)?",
      "captures": {
        "1": { "name": "support.type.deor" },
        "2": { "name": "support.type.deor" }
      }
    },
    "builtin-types": {
      "name": "support.type.deor",
      "match": "\\b(int|float|bool|string|bytes)\\b"
    },
    "constants": {
      "name": "constant.language.deor",
      "match": "\\b(true|false|none)\\b"
    },
    "number": {
      "name": "constant.numeric.deor",
      "match": "\\b\\d[\\d_]*(\\.[\\d_]+)?\\b"
    },
    "user-type": {
      "name": "entity.name.type.deor",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "function-call": {
      "name": "entity.name.function.deor",
      "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()"
    },
    "banned-operators": {
      "name": "invalid.illegal.deor",
      "match": "==|!=|&&|\\|\\|"
    },
    "operator": {
      "name": "keyword.operator.deor",
      "match": "\\+=|-=|\\*=|/=|%=|<=|>=|[+\\-*/%<>]|(?<![=!<>+\\-*/%])=(?![=])"
    }
  }
}
