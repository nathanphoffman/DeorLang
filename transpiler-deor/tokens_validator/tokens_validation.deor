# Libs

# Helper functions

# Macro Imports

shape fnTestRule = func of string to bool

# Walks the merged token list and enforces naming conventions before codegen runs.
# Prints all violations and exits with code 1 if any are found.
fn void validate_tokens(TokensRef tokens)
	int token_count = len(tokens)
	strList errors = empty
	int pos = 0
	int paren_depth = 0
	int block_depth = 0
	bool in_void_fn = false

	# labels
	string lbl_struct = "struct"
	string lbl_enum = "enum"
	string lbl_shape = "shape"
	string lbl_type = "type"
	string lbl_fn = "fn"
	string lbl_var = "variable"
	string lbl_call = "call to"
	string lbl_rust = "identifier"
	string lbl_decl = "declaration"
	string lbl_field = "struct field"
	string lbl_variant = "enum variant"

	# naming rules
	string rule_min3 = "name must be at least 3 characters"
	string rule_no_option = "Rust generic types (Option/Vec/Box/Rc/Arc/Result) are not valid in Deor — use shapes or validator types"
	string rule_pascal = "name must be PascalCase (start with uppercase letter)"
	string rule_camel = "name must be camelCase (start lowercase, no underscores)"
	string rule_snake = "name must be lower_snake_case (no uppercase letters)"
	string rule_named_arg = "each arg must be a named variable when passing 2 or more args"

	# declaration rules
	string rule_dup = "duplicate declaration — this name is already used by another struct, enum, shape, fn, or type"
	string rule_enum_pascal = "enum variant must be PascalCase"
	string rule_enum_data = "enum variants cannot carry data — use a struct alongside the enum instead"
	string rule_list_validator = "list shapes cannot be validator base types — validators only wrap primitives"

	# function rules
	string rule_max_params = "functions may have at most 3 parameters"
	string rule_param_shadow = "parameter name cannot be the same as its type — choose a descriptive name"
	string rule_no_ret = "missing return type — use 'fn void name()' for functions that return nothing"
	string rule_void_return = "void functions must not use return — remove the return statement and let the function fall through"
	string rule_void_var = "'void' is not a valid variable type — only functions can return void"
	string rule_crash = "crash takes exactly 1 string argument"

	# statement rules
	string rule_bad_stmt = "literal cannot follow 'name ident' — capture in a named variable first"
	string rule_typed_as = "typed `as` bindings are not supported — use `a as b` to transfer ownership, or `Type a = move b` for an explicit typed move"
	string rule_as_move = "`as` already transfers ownership — use `a as b` instead of `a as move b`"
	string rule_bracket_index = "bracket indexing is not valid in Deor — use 'name at index' instead"
	string rule_empty_bracket = "use 'empty' to initialize an empty list — [] is only valid with items inside"
	string rule_move = "'move' can only precede a variable name — 'move 5' or 'move \"hello\"' are not valid"
	string rule_not_is = "use 'x is not y' instead of 'not x is y' — 'not' binds before 'is' resolves"
	string rule_kw_in_parens = "reserved keyword cannot be used as a name — choose a different variable name"
	string rule_valid = "'valid' can only appear after 'is' or 'is not' — it cannot be assigned or returned"

	strList forbidden_in_parens = ["KW_LIST", "KW_STRUCT", "KW_SHAPE", "KW_ENUM", "KW_TYPE", "KW_FN", "KW_OF", "KW_FOR", "KW_IF", "KW_ELSE", "KW_RETURN", "KW_BREAK", "KW_CONTINUE", "KW_REMOVE", "KW_RUST", "KW_USING", "KW_IMPORT", "KW_MACRO", "KW_VOID", "KW_RAW"]

	# pre-scan: collect shape names + all decl names + validate struct/enum members
	strList shape_names = empty
	strList decl_names = empty
	int pre_i = 0
	for if pre_i < token_count
		Token pre_tok = tokens at pre_i
		(kind) in pre_tok
		macro_run prescan_collect_shapes
		macro_run prescan_check_duplicate_decls
		macro_run prescan_check_struct_fields
		macro_run prescan_check_enum_variants
		pre_i = pre_i + 1

	for if pos < token_count
		Token tok = tokens at pos
		(kind, value, line, file) in tok
		string cur_kind = kind
		string cur_val = value
		int cur_line = line
		string cur_file = file

		macro_run track_paren_depth
		macro_run track_block_scope
		macro_run check_void_return
		macro_run check_move_target
		macro_run check_keyword_in_parens
		macro_run skip_rust_block
		macro_run check_not_is_order

		validate_indent_offset as 1

		# struct name: PascalCase, min 3
		string keyword = "KW_STRUCT"
		string lbl = lbl_struct
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# enum name: PascalCase, min 3
		string keyword = "KW_ENUM"
		string lbl = lbl_enum
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# shape name: camelCase, min 3
		string keyword = "KW_SHAPE"
		string lbl = lbl_shape
		string rule = rule_camel
		fnTestRule test_rule = is_camel
		macro_run validate_ident

		# type name: PascalCase, min 3
		string keyword = "KW_TYPE"
		string lbl = lbl_type
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		macro_run check_type_base_not_shape
		macro_run check_fn_declaration

		# fn name: snake_case, min 3
		string keyword = "KW_FN"
		string lbl = lbl_fn
		string rule = rule_snake
		fnTestRule test_rule = is_snake
		int validate_indent_offset = 2
		macro_run validate_ident

		macro_run check_crash_args
		macro_run check_empty_bracket

		if cur_kind is "IDENT"
			bool is_fn_decl_name = false
			if pos > 1
				int prev2_p = pos - 2
				Token prev2_tok = tokens at prev2_p
				(kind) in prev2_tok
				is_fn_decl_name = kind is "KW_FN"
			if not is_fn_decl_name
				macro_run check_call_args
			macro_run check_rust_generic
			macro_run check_var_decl
			macro_run check_bad_stmt
			macro_run check_bracket_indexing

		macro_run check_void_var
		macro_run check_valid_placement

		pos = pos + 1

	handle_errors(errors)
