
# Generic delimiter skipper: when the current token matches `cur_indicator`, advances past tokens until `next_indicator`
# is found, then continues the outer loop. Used to skip over paired delimiters during validation passes.
macro skip_if_match
	if cur_kind is cur_indicator
		int skip_pos = pos + 1
		for if skip_pos < token_count
			Token skip_tok = tokens at skip_pos
			(kind) in skip_tok
			skip_pos = skip_pos + 1
			if kind is next_indicator
				break
		pos = skip_pos
		continue
