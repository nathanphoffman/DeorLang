
# Ensures `move` is followed by an IDENT or LPAREN — flags `move 5`, `move "hello"`, etc.
macro check_move_target
	if cur_kind is "KW_MOVE"
		int mv_next = pos + 1
		if mv_next < token_count
			Token mv_tok = tokens at mv_next
			(kind) in mv_tok
			bool mv_ok = kind is "IDENT"
			bool mv_destruct = kind is "LPAREN"
			bool mv_valid = mv_ok or mv_destruct
			if not mv_valid
				errors at end = val_err(tok, lbl_var, rule_move)
