
# Generic identifier validator: checks the name token at `validate_indent_offset` from the current keyword token
# for min-3-char length and a caller-supplied naming rule (snake, pascal, etc.). Advances past the keyword on match.
macro validate_ident
	if cur_kind is keyword
		int name_pos = pos + validate_indent_offset
		if name_pos < token_count
			Token name_tok = tokens at name_pos
			(kind, value) in name_tok
			string name_kind = kind
			string name_val = value
			if name_kind is "IDENT"
				if len(name_val) < 3
					errors at end = val_err(name_tok, lbl, rule_min3)
				if not test_rule(name_val)
					errors at end = val_err(name_tok, lbl, rule)
		pos = pos + 1
		continue
