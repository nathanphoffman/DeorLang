
# Prescan pass: collects const variable names into const_var_names so
# check_const_reassign can flag any later assignment to those variables.
macro prescan_collect_const_names
	if kind is "KW_CONST"
		int cn_name_pos = pre_i + 2
		if cn_name_pos < token_count
			Token cn_name_tok = tokens at cn_name_pos
			(kind, value) in cn_name_tok
			if kind is "IDENT"
				if not list_has(const_var_names, value)
					const_var_names at end = value
