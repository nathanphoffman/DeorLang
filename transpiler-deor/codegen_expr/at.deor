macro codegen_expr_at
	# index read: name at idx
	if kind is "KW_AT"
		int idx_pos = next_pos + 1
		ParseResult idx_r = gen_primary(tokens, idx_pos, ctx)
		move (code, new_pos) in idx_r
		idx_code as code
		idx_end as new_pos
		string idx_mid = "["
		string idx_sfx = " as usize].clone()"
		string idx_expr = s_join([value, idx_mid, idx_code, idx_sfx])
		return make_result(move idx_expr, idx_end)
