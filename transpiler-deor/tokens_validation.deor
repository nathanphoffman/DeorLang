# Libs

# Helper functions

# Macro Imports

shape fnTestRule = func of string to bool

# Walks the merged token list and enforces naming conventions before codegen runs.
# Prints all violations and exits with code 1 if any are found.
fn void validate_tokens(tokenList tokens)
	int token_count = len(tokens)
	strList errors = empty
	int pos = 0
	int paren_depth = 0
	string lbl_struct = "struct"
	string lbl_enum = "enum"
	string lbl_shape = "shape"
	string lbl_type = "type"
	string lbl_fn = "fn"
	string lbl_var = "variable"
	string lbl_call = "call to"
	string lbl_rust = "identifier"
	string rule_min3 = "name must be at least 3 characters"
	string rule_no_option = "Rust generic types (Option/Vec/Box/Rc/Arc/Result) are not valid in Deor — use shapes or validator types"
	string rule_pascal = "name must be PascalCase (start with uppercase letter)"
	string rule_camel = "name must be camelCase (start lowercase, no underscores)"
	string rule_snake = "name must be lower_snake_case (no uppercase letters)"
	string rule_named_arg = "each arg must be a named variable when passing 2 or more args"
	string rule_bad_stmt = "literal cannot follow 'name ident' — capture in a named variable first"
	string rule_not_is = "use 'x is not y' instead of 'not x is y' — 'not' binds before 'is' resolves"
	string rule_max_params = "functions may have at most 3 parameters"
	string rule_kw_in_parens = "reserved keyword cannot be used as a name — choose a different variable name"
	string rule_empty_bracket = "use 'empty' to initialize an empty list — [] is only valid with items inside"
	string rule_list_validator = "list shapes cannot be validator base types — validators only wrap primitives"
	strList forbidden_in_parens = ["KW_LIST", "KW_STRUCT", "KW_SHAPE", "KW_ENUM", "KW_TYPE", "KW_FN", "KW_OF", "KW_FOR", "KW_IF", "KW_ELSE", "KW_RETURN", "KW_BREAK", "KW_CONTINUE", "KW_REMOVE", "KW_RUST", "KW_USING", "KW_IMPORT", "KW_MACRO", "KW_VOID", "KW_RAW"]

	# pre-scan: collect all shape names for use in type validator check
	strList shape_names = empty
	int pre_i = 0
	for if pre_i < token_count
		Token pre_tok = tokens at pre_i
		(kind) in pre_tok
		if kind is "KW_SHAPE"
			int sn_pos = pre_i + 1
			if sn_pos < token_count
				Token sn_tok = tokens at sn_pos
				(value) in sn_tok
				shape_names at end = value
		pre_i = pre_i + 1

	for if pos < token_count
		Token tok = tokens at pos
		(kind, value, line, file) in tok
		string cur_kind = kind
		string cur_val = value
		int cur_line = line
		string cur_file = file

		# track paren depth for keyword-as-name detection
		if cur_kind is "LPAREN"
			paren_depth = paren_depth + 1
		if cur_kind is "RPAREN"
			paren_depth = paren_depth - 1

		# flag reserved keywords used as names inside ()
		if paren_depth > 0
			bool is_forbidden = list_has(forbidden_in_parens, cur_kind)
			if is_forbidden
				errors at end = val_err(tok, lbl_var, rule_kw_in_parens)

		# skip rust blocks entirely — their content is raw Rust and not subject to Deor rules
		string cur_indicator = "KW_RUST"
		string next_indicator = "RUST_BLOCK"
		macro_run skip_if_match

		# forces "not is" rather than not X is
		if cur_kind is "KW_NOT"
			int next_not = pos + 1
			int after_not = pos + 2
			
			if after_not < token_count
				Token next_not_tok = tokens at next_not
				Token after_not_tok = tokens at after_not

				(kind) in next_not_tok
				string next_not_kind = kind
				(kind) in after_not_tok
				string after_not_kind = kind

				bool next_is_ident = next_not_kind is "IDENT"
				bool after_is_is = after_not_kind is "KW_IS"

				if next_is_ident and after_is_is
					(value) in next_not_tok
					errors at end = val_err(next_not_tok, lbl_var, rule_not_is)

		###########################  These are validators for each type #####################
		
		validate_indent_offset as 1
	
		# Struct Validator
		string keyword = "KW_STRUCT"
		string lbl = lbl_struct
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# Enum Validator
		string keyword = "KW_ENUM"
		string lbl = lbl_enum
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# Shape Validator
		string keyword = "KW_SHAPE"
		string lbl = lbl_shape
		string rule = rule_camel
		fnTestRule test_rule = is_camel
		macro_run validate_ident

		# Type Validator → PascalCase, min 3; also ban list shapes as base types
		string keyword = "KW_TYPE"
		string lbl = lbl_type
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		if cur_kind is "KW_TYPE"
			int base_type_pos = pos + 3
			if base_type_pos < token_count
				Token base_type_tok = tokens at base_type_pos
				(value) in base_type_tok
				bool base_is_shape = list_has(shape_names, value)
				if base_is_shape
					int type_name_pos = pos + 1
					Token type_name_tok = tokens at type_name_pos
					errors at end = val_err(type_name_tok, lbl_type, rule_list_validator)

		# Fn param count: max 3 parameters
		# pattern: KW_FN <return_type> <fn_name> LPAREN params RPAREN
		if cur_kind is "KW_FN"
			int lp_pos = pos + 3
			if lp_pos < token_count
				Token lp_tok = tokens at lp_pos
				(kind) in lp_tok
				if kind is "LPAREN"
					int param_count = count_call_args(tokens, lp_pos)
					if param_count > 3
						int fn_name_pos = pos + 2
						Token fn_name_tok = tokens at fn_name_pos
						errors at end = val_err(fn_name_tok, lbl_fn, rule_max_params)

			# missing return type: KW_FN IDENT LPAREN — no room for both return type and fn name
			string rule_no_ret = "missing return type — use 'fn void name()' for functions that return nothing"
			int ret_pos = pos + 1
			int lp2_pos = pos + 2
			if lp2_pos < token_count
				Token ret_tok = tokens at ret_pos
				Token lp2_tok = tokens at lp2_pos
				(kind) in ret_tok
				string ret_kind = kind
				(kind) in lp2_tok
				if ret_kind is "IDENT"
					if kind is "LPAREN"
						errors at end = val_err(ret_tok, lbl_fn, rule_no_ret)

		# Fn Validator → lower_snake_case, min 3
		# pattern: KW_FN <return_type> <fn_name> LPAREN
		string keyword = "KW_FN"
		string lbl = lbl_fn
		string rule = rule_snake
		fnTestRule test_rule = is_snake
		# unlike other validators, we skip ahead to skip over type to reach ident
		int validate_indent_offset = 2
		macro_run validate_ident

		# crash must take exactly 1 string argument
		if cur_kind is "IDENT"
			bool is_crash = cur_val is "crash"
			if is_crash
				int crash_lp = pos + 1
				if crash_lp < token_count
					Token crash_lp_tok = tokens at crash_lp
					(kind) in crash_lp_tok
					if kind is "LPAREN"
						int crash_arg_count = count_call_args(tokens, crash_lp)
						bool wrong_count = crash_arg_count is not 1
						if wrong_count
							string rule_crash = "crash takes exactly 1 string argument"
							errors at end = val_err(tok, lbl_call, rule_crash)

		# [] with nothing inside is always an empty list init — must use empty instead
		if cur_kind is "LBRACKET"
			int next_pos = pos + 1
			if next_pos < token_count
				Token next_tok = tokens at next_pos
				(kind) in next_tok
				if kind is "RBRACKET"
					errors at end = val_err(tok, lbl_var, rule_empty_bracket)

		# variable declaration: TYPE_IDENT VAR_NAME EQUALS
		# struct fields are TYPE_IDENT FIELD_NAME NEWLINE (no EQUALS), so this is safe
		if cur_kind is "IDENT"
			macro_run check_call_args
			macro_run check_rust_generic
			macro_run check_var_decl
			macro_run check_bad_stmt

			int next_pos = pos + 1
			if next_pos < token_count
				Token next_tok = tokens at next_pos
				(kind) in next_tok
				string bracket_rule = "bracket indexing is not valid in Deor — use 'name at index' instead"
				if kind is "LBRACKET"
					errors at end = val_err(tok, lbl_var, bracket_rule)

		pos = pos + 1

	handle_errors(errors)
