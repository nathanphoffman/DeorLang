(tokenList, Token) in "transpiler-deor/types.deor"
(s_cat) in "transpiler-deor/lib/string.deor"
(c_chars) in "transpiler-deor/lib/char.deor"
(n_to_str) in "transpiler-deor/lib/num.deor"

fn bool is_upper_char(string ch)
	rust
		ch.chars().next().map(|c| c.is_uppercase()).unwrap_or(false)

fn bool is_lower_char(string ch)
	rust
		ch.chars().next().map(|c| c.is_lowercase()).unwrap_or(false)

# First char uppercase → PascalCase
fn bool is_pascal(string name)
	strList chars = c_chars(name)
	int n = len(chars)
	if n is 0
		return false
	string first = chars at 0
	return is_upper_char(first)

# First char lowercase, no underscores → camelCase
fn bool is_camel(string name)
	strList chars = c_chars(name)
	int n = len(chars)
	if n is 0
		return false
	string first = chars at 0
	if not is_lower_char(first)
		return false
	int i = 0
	for if i < n
		string ch = chars at i
		if ch is "_"
			return false
		i = i + 1
	return true

# No uppercase letters → lower_snake_case
fn bool is_snake(string name)
	strList chars = c_chars(name)
	int n = len(chars)
	int i = 0
	for if i < n
		string ch = chars at i
		if is_upper_char(ch)
			return false
		i = i + 1
	return true

fn string val_err(int line_num, string label, string name, string rule)
	return s_cat("[validation] line ", s_cat(n_to_str(line_num), s_cat(": ", s_cat(label, s_cat(" '", s_cat(name, s_cat("' - ", rule)))))))

# Walks the merged token list and enforces naming conventions before codegen runs.
# Prints all violations and exits with code 1 if any are found.
fn void validate_tokens(tokenList tokens)
	int token_count = len(tokens)
	strList errors = []
	int pos = 0

	for if pos < token_count
		Token tok = tokens at pos
		(kind) in tok
		string cur_kind = kind
		(line) in tok
		int cur_line = line

		# struct → PascalCase, min 3
		if cur_kind is "KW_STRUCT"
			int np = pos + 1
			if np < token_count
				Token nt = tokens at np
				(kind, value) in nt
				string nt_kind = kind
				string nt_val = value
				if nt_kind is "IDENT"
					if len(nt_val) < 3
						errors at end = val_err(cur_line, "struct", nt_val, "name must be at least 3 characters")
					if not is_pascal(nt_val)
						errors at end = val_err(cur_line, "struct", nt_val, "name must be PascalCase (start with uppercase letter)")
			pos = pos + 1
			continue

		# enum → PascalCase, min 3
		if cur_kind is "KW_ENUM"
			int np = pos + 1
			if np < token_count
				Token nt = tokens at np
				(kind, value) in nt
				string nt_kind = kind
				string nt_val = value
				if nt_kind is "IDENT"
					if len(nt_val) < 3
						errors at end = val_err(cur_line, "enum", nt_val, "name must be at least 3 characters")
					if not is_pascal(nt_val)
						errors at end = val_err(cur_line, "enum", nt_val, "name must be PascalCase (start with uppercase letter)")
			pos = pos + 1
			continue

		# shape → camelCase, min 3
		if cur_kind is "KW_SHAPE"
			int np = pos + 1
			if np < token_count
				Token nt = tokens at np
				(kind, value) in nt
				string nt_kind = kind
				string nt_val = value
				if nt_kind is "IDENT"
					if len(nt_val) < 3
						errors at end = val_err(cur_line, "shape", nt_val, "name must be at least 3 characters")
					if not is_camel(nt_val)
						errors at end = val_err(cur_line, "shape", nt_val, "name must be camelCase (start lowercase, no underscores)")
			pos = pos + 1
			continue

		# type → camelCase, min 3
		if cur_kind is "KW_TYPE"
			int np = pos + 1
			if np < token_count
				Token nt = tokens at np
				(kind, value) in nt
				string nt_kind = kind
				string nt_val = value
				if nt_kind is "IDENT"
					if len(nt_val) < 3
						errors at end = val_err(cur_line, "type", nt_val, "name must be at least 3 characters")
					if not is_camel(nt_val)
						errors at end = val_err(cur_line, "type", nt_val, "name must be camelCase (start lowercase, no underscores)")
			pos = pos + 1
			continue

		# fn → lower_snake_case, min 3
		# pattern: KW_FN <return_type> <fn_name> LPAREN
		# return type is always one token (IDENT or KW_VOID), so fn name is at pos+2
		if cur_kind is "KW_FN"
			int np = pos + 2
			if np < token_count
				Token nt = tokens at np
				(kind, value) in nt
				string nt_kind = kind
				string nt_val = value
				if nt_kind is "IDENT"
					if len(nt_val) < 3
						errors at end = val_err(cur_line, "fn", nt_val, "name must be at least 3 characters")
					if not is_snake(nt_val)
						errors at end = val_err(cur_line, "fn", nt_val, "name must be lower_snake_case (no uppercase letters)")
			pos = pos + 1
			continue

		# variable declaration: TYPE_IDENT VAR_NAME EQUALS
		# struct fields are TYPE_IDENT FIELD_NAME NEWLINE (no EQUALS), so this is safe
		if cur_kind is "IDENT"
			int next1 = pos + 1
			int next2 = pos + 2
			if next2 < token_count
				Token t1 = tokens at next1
				Token t2 = tokens at next2
				(kind) in t1
				string t1k = kind
				(kind) in t2
				string t2k = kind
				if t1k is "IDENT" and t2k is "EQUALS"
					(value, line) in t1
					string var_name = value
					int var_line = line
					if len(var_name) < 3
						errors at end = val_err(var_line, "variable", var_name, "name must be at least 3 characters")
					if not is_snake(var_name)
						errors at end = val_err(var_line, "variable", var_name, "name must be lower_snake_case (no uppercase letters)")

		pos = pos + 1

	int error_count = len(errors)
	if error_count > 0
		int ei = 0
		for if ei < error_count
			string err_msg = errors at ei
			print(err_msg)
			ei = ei + 1
		rust
			std::process::exit(1);
