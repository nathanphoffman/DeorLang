(tokenList, Token) in "transpiler-deor/types.deor"
(s_cat) in "transpiler-deor/lib/string.deor"
(c_chars) in "transpiler-deor/lib/char.deor"
(n_to_str) in "transpiler-deor/lib/num.deor"

fn bool is_upper_char(string ch)
	rust
		ch.chars().next().map(|c| c.is_uppercase()).unwrap_or(false)

fn bool is_lower_char(string ch)
	rust
		ch.chars().next().map(|c| c.is_lowercase()).unwrap_or(false)

# First char uppercase → PascalCase
fn bool is_pascal(string name)
	strList chars = c_chars(name)
	int name_len = len(chars)
	if name_len is 0
		return false
	string first = chars at 0
	return is_upper_char(first)

# First char lowercase, no underscores → camelCase
fn bool is_camel(string name)
	strList chars = c_chars(name)
	int name_len = len(chars)
	if name_len is 0
		return false
	string first = chars at 0
	if not is_lower_char(first)
		return false
	int idx = 0
	for if idx < name_len
		string chr = chars at idx
		if chr is "_"
			return false
		idx = idx + 1
	return true

# No uppercase letters → lower_snake_case
fn bool is_snake(string name)
	strList chars = c_chars(name)
	int name_len = len(chars)
	int idx = 0
	for if idx < name_len
		string chr = chars at idx
		if is_upper_char(chr)
			return false
		idx = idx + 1
	return true

fn string val_err(int line_num, string label, string name, string rule)
	return s_cat("[validation] line ", s_cat(n_to_str(line_num), s_cat(": ", s_cat(label, s_cat(" '", s_cat(name, s_cat("' - ", rule)))))))

# Walks the merged token list and enforces naming conventions before codegen runs.
# Prints all violations and exits with code 1 if any are found.
fn void validate_tokens(tokenList tokens)
	int token_count = len(tokens)
	strList errors = []
	int pos = 0

	for if pos < token_count
		Token tok = tokens at pos
		(kind) in tok
		string cur_kind = kind
		(line) in tok
		int cur_line = line

		# struct → PascalCase, min 3
		if cur_kind is "KW_STRUCT"
			int name_pos = pos + 1
			if name_pos < token_count
				Token name_tok = tokens at name_pos
				(kind, value) in name_tok
				string name_kind = kind
				string name_val = value
				if name_kind is "IDENT"
					if len(name_val) < 3
						errors at end = val_err(cur_line, "struct", name_val, "name must be at least 3 characters")
					if not is_pascal(name_val)
						errors at end = val_err(cur_line, "struct", name_val, "name must be PascalCase (start with uppercase letter)")
			pos = pos + 1
			continue

		# enum → PascalCase, min 3
		if cur_kind is "KW_ENUM"
			int name_pos = pos + 1
			if name_pos < token_count
				Token name_tok = tokens at name_pos
				(kind, value) in name_tok
				string name_kind = kind
				string name_val = value
				if name_kind is "IDENT"
					if len(name_val) < 3
						errors at end = val_err(cur_line, "enum", name_val, "name must be at least 3 characters")
					if not is_pascal(name_val)
						errors at end = val_err(cur_line, "enum", name_val, "name must be PascalCase (start with uppercase letter)")
			pos = pos + 1
			continue

		# shape → camelCase, min 3
		if cur_kind is "KW_SHAPE"
			int name_pos = pos + 1
			if name_pos < token_count
				Token name_tok = tokens at name_pos
				(kind, value) in name_tok
				string name_kind = kind
				string name_val = value
				if name_kind is "IDENT"
					if len(name_val) < 3
						errors at end = val_err(cur_line, "shape", name_val, "name must be at least 3 characters")
					if not is_camel(name_val)
						errors at end = val_err(cur_line, "shape", name_val, "name must be camelCase (start lowercase, no underscores)")
			pos = pos + 1
			continue

		# type → camelCase, min 3
		if cur_kind is "KW_TYPE"
			int name_pos = pos + 1
			if name_pos < token_count
				Token name_tok = tokens at name_pos
				(kind, value) in name_tok
				string name_kind = kind
				string name_val = value
				if name_kind is "IDENT"
					if len(name_val) < 3
						errors at end = val_err(cur_line, "type", name_val, "name must be at least 3 characters")
					if not is_camel(name_val)
						errors at end = val_err(cur_line, "type", name_val, "name must be camelCase (start lowercase, no underscores)")
			pos = pos + 1
			continue

		# fn → lower_snake_case, min 3
		# pattern: KW_FN <return_type> <fn_name> LPAREN
		# return type is always one token (IDENT or KW_VOID), so fn name is at pos+2
		if cur_kind is "KW_FN"
			int name_pos = pos + 2
			if name_pos < token_count
				Token name_tok = tokens at name_pos
				(kind, value) in name_tok
				string name_kind = kind
				string name_val = value
				if name_kind is "IDENT"
					if len(name_val) < 3
						errors at end = val_err(cur_line, "fn", name_val, "name must be at least 3 characters")
					if not is_snake(name_val)
						errors at end = val_err(cur_line, "fn", name_val, "name must be lower_snake_case (no uppercase letters)")
			pos = pos + 1
			continue

		# variable declaration: TYPE_IDENT VAR_NAME EQUALS
		# struct fields are TYPE_IDENT FIELD_NAME NEWLINE (no EQUALS), so this is safe
		if cur_kind is "IDENT"
			int next1 = pos + 1
			int next2 = pos + 2
			if next2 < token_count
				Token tok_one = tokens at next1
				Token tok_two = tokens at next2
				(kind) in tok_one
				string one_kind = kind
				(kind) in tok_two
				string two_kind = kind
				if one_kind is "IDENT" and two_kind is "EQUALS"
					(value, line) in tok_one
					string var_name = value
					int var_line = line
					if len(var_name) < 3
						errors at end = val_err(var_line, "variable", var_name, "name must be at least 3 characters")
					if not is_snake(var_name)
						errors at end = val_err(var_line, "variable", var_name, "name must be lower_snake_case (no uppercase letters)")

		pos = pos + 1

	int error_count = len(errors)
	if error_count > 0
		int err_idx = 0
		for if err_idx < error_count
			string err_msg = errors at err_idx
			print(err_msg)
			err_idx = err_idx + 1
		rust
			std::process::exit(1);
