# Libs
import "transpiler-deor/types.deor"
import "transpiler-deor/lib/string.deor"
import "transpiler-deor/lib/char.deor"
import "transpiler-deor/lib/num.deor"

# Helper functions
import "transpiler-deor/tokens_validator/casing.deor"
import "transpiler-deor/tokens_validator/arg_helpers.deor"
import "transpiler-deor/tokens_validator/error_handling.deor"

# Macro Imports
import "transpiler-deor/tokens_validator/macros/ident_validator.deor"
import "transpiler-deor/tokens_validator/macros/skip_if_match.deor"
import "transpiler-deor/tokens_validator/macros/check_var_decl.deor"
import "transpiler-deor/tokens_validator/macros/check_rust_generic.deor"
import "transpiler-deor/tokens_validator/macros/check_call_args.deor"

shape fnTestRule = func of string to bool

# Walks the merged token list and enforces naming conventions before codegen runs.
# Prints all violations and exits with code 1 if any are found.
fn void validate_tokens(tokenList tokens)
	int token_count = len(tokens)
	strList errors = []
	int pos = 0
	string lbl_struct = "struct"
	string lbl_enum = "enum"
	string lbl_shape = "shape"
	string lbl_type = "type"
	string lbl_fn = "fn"
	string lbl_var = "variable"
	string lbl_call = "call to"
	string lbl_rust = "identifier"
	string rule_min3 = "name must be at least 3 characters"
	string rule_no_option = "Rust generic types (Option/Vec/Box/Rc/Arc/Result) are not valid in Deor — use shapes or validator types"
	string rule_pascal = "name must be PascalCase (start with uppercase letter)"
	string rule_camel = "name must be camelCase (start lowercase, no underscores)"
	string rule_snake = "name must be lower_snake_case (no uppercase letters)"
	string rule_named_arg = "each arg must be a named variable when passing 2 or more args"
	string rule_not_is = "use 'x is not y' instead of 'not x is y' — 'not' binds before 'is' resolves"

	for if pos < token_count
		Token tok = tokens at pos
		(kind, value, line, file) in tok
		string cur_kind = kind
		string cur_val = value
		int cur_line = line
		string cur_file = file

		# skip macro_define headers — name(place p1, place p2) is a declaration, not a call
		string cur_indicator = "KW_MACRO_DEFINE"
		string next_indicator = "RPAREN"
		macro_run skip_if_match

		# skip rust blocks entirely — their content is raw Rust and not subject to Deor rules
		string cur_indicator = "KW_RUST"
		string next_indicator = "RUST_BLOCK"
		macro_run skip_if_match

		# forces "not is" rather than not X is
		if cur_kind is "KW_NOT"
			int next_not = pos + 1
			int after_not = pos + 2
			
			if after_not < token_count
				Token next_not_tok = tokens at next_not
				Token after_not_tok = tokens at after_not

				(kind) in next_not_tok
				string next_not_kind = kind
				(kind) in after_not_tok
				string after_not_kind = kind

				bool next_is_ident = next_not_kind is "IDENT"
				bool after_is_is = after_not_kind is "KW_IS"

				if next_is_ident and after_is_is
					(value) in next_not_tok
					errors at end = val_err(cur_file, cur_line, lbl_var, value, rule_not_is)

		###########################  These are validators for each type #####################
		
		validate_indent_offset as 1
	
		# Struct Validator
		string keyword = "KW_STRUCT"
		string lbl = lbl_struct
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# Enum Validator
		string keyword = "KW_ENUM"
		string lbl = lbl_enum
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# Shape Validator
		string keyword = "KW_SHAPE"
		string lbl = lbl_shape
		string rule = rule_camel
		fnTestRule test_rule = is_camel
		macro_run validate_ident

		# Type Validator → camelCase, min 3
		string keyword = "KW_TYPE"
		string lbl = lbl_type
		string rule = rule_pascal
		fnTestRule test_rule = is_pascal
		macro_run validate_ident

		# Fn Validator → lower_snake_case, min 3
		# pattern: KW_FN <return_type> <fn_name> LPAREN
		string keyword = "KW_FN"
		string lbl = lbl_fn
		string rule = rule_snake
		fnTestRule test_rule = is_snake
		# unlike other validators, we skip ahead to skip over type to reach ident
		int validate_indent_offset = 2
		macro_run validate_ident

		# variable declaration: TYPE_IDENT VAR_NAME EQUALS
		# struct fields are TYPE_IDENT FIELD_NAME NEWLINE (no EQUALS), so this is safe
		if cur_kind is "IDENT"
			macro_run check_call_args
			macro_run check_rust_generic
			macro_run check_var_decl

		pos = pos + 1

	handle_errors(errors)
