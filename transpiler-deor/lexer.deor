(tokenList, Token) in "transpiler-deor/types.deor"
(s_cat, s_join_nl, s_rtrim, s_trim, s_from, s_split) in "transpiler-deor/lib/string.deor"
(c_chars, c_alpha, c_digit, c_alnum) in "transpiler-deor/lib/char.deor"
(n_parse, n_to_str) in "transpiler-deor/lib/num.deor"
(make_token) in "transpiler-deor/deor_helpers.deor"
(word_to_kind) in "transpiler-deor/mappings.deor"
(is_empty) in "transpiler-deor/utils.deor"

# === Lexer ===

# Counts leading tab characters in a single source line to determine indentation level.
# Deor uses tabs for block nesting; this count is compared against the indent stack
# to decide whether to emit INDENT or DEDENT tokens for the current line.
fn int count_tabs(string line)
	strList chars = c_chars(line)
	int char_count = len(chars)
	int count = 0
	for index in range(char_count)
		string character = chars at index
		if character is "\t"
			count = count + 1
		else
			break
	return count

# Full Deor lexer. Converts raw source text into a flat token list. Handles:
# indentation-based INDENT/DEDENT pairs; `rust` blocks captured verbatim as a single
# RUST_BLOCK token; string literals with escape sequences; integer literals; identifiers
# and keywords (dispatched via word_to_kind); two-character operators (>=, <=); and
# single-character operators/punctuation. Emits trailing DEDENTs and a terminal EOF.
fn tokenList tokenize(string source)
	tokenList tokens = []
	string newline = "\n"
	strList lines = s_split(source, newline)
	int n_lines = len(lines)
	strList indent_stack = []
	string zero_str = "0"
	indent_stack at end = zero_str
	int cur_line = 0
	int skip = 0
	string empty_val = ""
	string kind_indent = "INDENT"
	string kind_dedent = "DEDENT"
	string kind_newline = "NEWLINE"
	string kind_kw_rust = "KW_RUST"
	string kw_rust_val = "rust"
	string kind_rust_block = "RUST_BLOCK"
	string kind_string = "STRING"
	string kind_int = "INT"
	string kind_eof = "EOF"
	string kind_gte = "GTE"
	string kind_lte = "LTE"
	string kind_plus = "PLUS"
	string kind_minus = "MINUS"
	string kind_star = "STAR"
	string kind_slash = "SLASH"
	string kind_pct = "PERCENT"
	string kind_eq = "EQUALS"
	string kind_gt = "GT"
	string kind_lt = "LT"
	string kind_lp = "LPAREN"
	string kind_rp = "RPAREN"
	string kind_lb = "LBRACKET"
	string kind_rb = "RBRACKET"
	string kind_cm = "COMMA"
	string val_gte = ">="
	string val_lte = "<="
	string val_plus = "+"
	string val_minus = "-"
	string val_star = "*"
	string val_slash = "/"
	string val_pct = "%"
	string val_eq = "="
	string val_gt = ">"
	string val_lt = "<"
	string val_lp = "("
	string val_rp = ")"
	string val_lb = "["
	string val_rb = "]"
	string val_cm = ","
	string ch_nl = "\n"
	string ch_tab = "\t"
	string ch_bs = "\\"
	string ch_qt = "\""

	for raw_li in range(n_lines)
		cur_line = cur_line + 1
		if skip > 0
			skip = skip - 1
			continue

		string raw_line = lines at raw_li
		string line = s_rtrim(raw_line)
		string stripped = s_trim(line)

		if is_empty(stripped)
			continue

		int indent = count_tabs(line)
		string content = s_from(line, indent)

		# handle indent/dedent relative to stack top
		int slen = len(indent_stack)
		int top_idx = slen - 1
		int top = n_parse(indent_stack at top_idx)

		if indent > top
			tokens at end = make_token(kind_indent, empty_val, cur_line)
			string indent_str = n_to_str(indent)
			indent_stack at end = indent_str
		else
			bool dedenting = indent < top
			for if dedenting
				int new_slen = len(indent_stack)
				int new_top_idx = new_slen - 1
				int cur_top = n_parse(indent_stack at new_top_idx)
				if indent < cur_top
					tokens at end = make_token(kind_dedent, empty_val, cur_line)
					indent_stack remove at new_top_idx
				else
					dedenting = false

		# rust block: entire content (trimmed) is exactly "rust"
		if content is "rust"
			tokens at end = make_token(kind_kw_rust, kw_rust_val, cur_line)
			tokens at end = make_token(kind_newline, empty_val, cur_line)
			int rust_base = indent + 1
			strList rust_lines = []
			int rli_start = raw_li + 1
			for rli in (rli_start, n_lines)
				string rust_line = lines at rli
				int rl_indent = count_tabs(rust_line)
				string rl_stripped = s_trim(rust_line)
				if is_empty(rl_stripped)
					rust_lines at end = ""
					skip = skip + 1
				else if rl_indent >= rust_base
					string rl_content = s_from(rust_line, rust_base)
					rust_lines at end = s_rtrim(rl_content)
					skip = skip + 1
				else
					break
			# trim trailing empty lines
			bool trimming = true
			for if trimming
				int rl_len = len(rust_lines)
				if rl_len > 0
					int last_rl = rl_len - 1
					string last_line = rust_lines at last_rl
					if last_line is ""
						rust_lines remove at last_rl
					else
						trimming = false
				else
					trimming = false
			string block_content = s_join_nl(rust_lines)
			tokens at end = make_token(kind_rust_block, block_content, cur_line)
			continue

		# scan content characters for tokens
		strList chars = c_chars(content)
		int char_count = len(chars)
		int char_index = 0

		for if char_index < char_count
			string character = chars at char_index

			if character is " "
				char_index = char_index + 1
				continue

			# comment: skip rest of line
			if character is "#"
				break

			# string literal
			if character is "\""
				string val = ""
				bool escape_next = false
				int str_start = char_index + 1
				char_index = char_index + 1
				for string_index in (str_start, char_count)
					string string_char = chars at string_index
					if escape_next
						if string_char is "n"
							val = s_cat(val, ch_nl)
						else if string_char is "t"
							val = s_cat(val, ch_tab)
						else if string_char is "\\"
							val = s_cat(val, ch_bs)
						else if string_char is "\""
							val = s_cat(val, ch_qt)
						else
							val = s_cat(val, ch_bs)
							val = s_cat(val, string_char)
						escape_next = false
						char_index = string_index + 1
					else if string_char is ch_bs
						escape_next = true
						char_index = string_index + 1
					else if string_char is ch_qt
						char_index = string_index + 1
						break
					else
						val = s_cat(val, string_char)
						char_index = string_index + 1
				tokens at end = make_token(kind_string, val, cur_line)
				continue

			# integer literal
			if c_digit(character)
				string num = s_cat(empty_val, character)
				int num_start = char_index + 1
				char_index = char_index + 1
				for number_index in (num_start, char_count)
					string number_char = chars at number_index
					if c_digit(number_char)
						num = s_cat(num, number_char)
						char_index = number_index + 1
					else
						break
				tokens at end = make_token(kind_int, num, cur_line)
				continue

			# identifier or keyword
			if c_alpha(character)
				string word = s_cat(empty_val, character)
				int word_start = char_index + 1
				char_index = char_index + 1
				for word_index in (word_start, char_count)
					string word_char = chars at word_index
					if c_alnum(word_char)
						word = s_cat(word, word_char)
						char_index = word_index + 1
					else
						break
				string word_kind = word_to_kind(word)
				tokens at end = make_token(word_kind, word, cur_line)
				continue

			# two-char operators
			int peek_idx = char_index + 1
			string peek = ""
			if peek_idx < char_count
				peek = chars at peek_idx

			if character is ">" and peek is "="
				tokens at end = make_token(kind_gte, val_gte, cur_line)
				char_index = char_index + 2
				continue
			if character is "<" and peek is "="
				tokens at end = make_token(kind_lte, val_lte, cur_line)
				char_index = char_index + 2
				continue

			# single-char tokens
			if character is "+"
				tokens at end = make_token(kind_plus, val_plus, cur_line)
			else if character is "-"
				tokens at end = make_token(kind_minus, val_minus, cur_line)
			else if character is "*"
				tokens at end = make_token(kind_star, val_star, cur_line)
			else if character is "/"
				tokens at end = make_token(kind_slash, val_slash, cur_line)
			else if character is "%"
				tokens at end = make_token(kind_pct, val_pct, cur_line)
			else if character is "="
				tokens at end = make_token(kind_eq, val_eq, cur_line)
			else if character is ">"
				tokens at end = make_token(kind_gt, val_gt, cur_line)
			else if character is "<"
				tokens at end = make_token(kind_lt, val_lt, cur_line)
			else if character is "("
				tokens at end = make_token(kind_lp, val_lp, cur_line)
			else if character is ")"
				tokens at end = make_token(kind_rp, val_rp, cur_line)
			else if character is "["
				tokens at end = make_token(kind_lb, val_lb, cur_line)
			else if character is "]"
				tokens at end = make_token(kind_rb, val_rb, cur_line)
			else if character is ","
				tokens at end = make_token(kind_cm, val_cm, cur_line)
			char_index = char_index + 1

		tokens at end = make_token(kind_newline, empty_val, cur_line)

	# emit remaining DEDENTs
	int final_stack_len = len(indent_stack)
	for in (1, final_stack_len)
		tokens at end = make_token(kind_dedent, empty_val, cur_line)

	tokens at end = make_token(kind_eof, empty_val, cur_line)
	return tokens
