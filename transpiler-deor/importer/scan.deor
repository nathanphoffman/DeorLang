
# Import path scanners used by load.deor.

# Handles `import "path"` — KW_IMPORT is at pos, STRING path is at pos+1.
fn ParseResult scan_import_new(tokenList tokens, int pos)
	int path_pos = pos + 1
	int token_count = len(tokens)
	if path_pos < token_count
		Token path_tok = tokens at path_pos
		(kind, value) in path_tok
		if kind is "STRING"
			int after_path = path_pos + 1
			return make_result(value, after_path)
	string emp = ""
	return make_result(emp, pos)

# Scans for `where Placeholder = ConcreteType` immediately after an import path.
# pos should be the token position right after the STRING path token.
# Returns code="Placeholder|ConcreteType" and new_pos=position after the clause.
# Returns code="" and new_pos=pos if no where clause is present.
fn ParseResult scan_import_where(tokenList tokens, int pos)
	int token_count = len(tokens)
	int where_pos = pos
	int replacement_pos = pos + 1
	int eq_pos = pos + 2
	int concrete_pos = pos + 3
	if concrete_pos < token_count
		Token where_tok = tokens at where_pos
		(kind, value) in where_tok
		bool is_where = kind is "IDENT" and value is "where"
		if is_where
			Token eq_tok = tokens at eq_pos
			Token concrete_tok = tokens at concrete_pos
			Token replacement_tok = tokens at replacement_pos
			(kind) in eq_tok
			bool is_eq = kind is "EQUALS"
			if is_eq
				(value) in replacement_tok
				replacement_value as value

				(value) in concrete_tok
				int after_where = concrete_pos + 1

				replace_with as replacement_value + "|" + value
				return make_result(replace_with, after_where)
	string emp = ""
	return make_result(emp, pos)
