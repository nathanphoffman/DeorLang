
# Scans forward from pos to find the end of a single-line declaration (shape/raw).
# Stops after the first NEWLINE token.
# Writes: end_pos (int) — position of the token after the NEWLINE
# Reads:  pos, token_count, tokens
macro find_shape_end
	int fse_cur = pos
	for if fse_cur < token_count
		Token fse_tok = tokens at fse_cur
		(kind) in fse_tok
		fse_cur = fse_cur + 1
		if kind is "NEWLINE"
			break
	int end_pos = fse_cur
