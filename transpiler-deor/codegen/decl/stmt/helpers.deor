
# Applies ownership coercion to a value about to be pushed into a list.
# String literals need `.to_string()`, identifiers need `.clone()`. Expressions
# produced by calls or arithmetic are already owned and pass through unchanged.
fn string emit_val(string val_code, string val_kind)
	macro_run rust_strings
	if val_kind is "STRING"
		return s_join([val_code, rs_tos])
	if val_kind is "IDENT"
		return s_join([val_code, rs_cln])
	return val_code
