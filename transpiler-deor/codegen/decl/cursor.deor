
# Constructs a fresh TokenCursor anchored at `pos`. Used to start cursor-based
# traversal at the beginning of a declaration body during code generation.
fn TokenCursor cur_at(tokenList tokens, int pos)
	int token_count = len(tokens)
	Token current = tokens at pos
	cur as (token_count, pos, current)
	return cur

# Advances the cursor by one position and updates `current` to the new token.
# Returns the same cursor value unchanged if already at the end of the stream.
fn TokenCursor cur_next(TokenCursor cur, tokenList tokens)
	(token_count, pos, current) in cur
	int pos = pos + 1
	if pos < token_count
		Token current = tokens at pos
		return (token_count, pos, current)
	return (token_count, pos, current)

# Returns true when the cursor has consumed all tokens.
fn bool c_at_end(TokenCursor cur)
	(token_count, pos) in cur
	return pos >= token_count

# Advances the cursor past the NEWLINE and INDENT that follow a declaration header,
# positioning it at the first statement token inside the block body.
fn TokenCursor cur_skip_to_body(TokenCursor cur, tokenList tokens)
	(pos) in cur
	int body_pos = adv_nl(pos, tokens)
	body_pos = adv_indent(body_pos, tokens)
	return cur_at(tokens, body_pos)

# Returns the token at current_pos + `offset` without advancing the cursor.
# Allows one-token (or multi-token) look-ahead during parsing without mutating state.
fn Token cur_peek(TokenCursor cur, tokenList tokens, int offset)
	(pos) in cur
	int peek_pos = pos + offset
	return tokens at peek_pos

fn TokenCursor cur_at_ref(TokensRef tokens, int pos)
	int token_count = len(tokens)
	Token current = tokens at pos
	cur as (token_count, pos, current)
	return cur

fn TokenCursor cur_next_ref(TokenCursor cur, TokensRef tokens)
	(token_count, pos, current) in cur
	int pos = pos + 1
	if pos < token_count
		Token current = tokens at pos
		return (token_count, pos, current)
	return (token_count, pos, current)

fn TokenCursor cur_skip_to_body_ref(TokenCursor cur, TokensRef tokens)
	(pos) in cur
	int body_pos = adv_nl_ref(pos, tokens)
	body_pos = adv_indent_ref(body_pos, tokens)
	return cur_at_ref(tokens, body_pos)

fn Token cur_peek_ref(TokenCursor cur, TokensRef tokens, int offset)
	(pos) in cur
	int peek_pos = pos + offset
	return tokens at peek_pos
