
# Converts a Deor primitive type name to the Rust equivalent: intâ†’i32, stringâ†’String,
# floatâ†’f64, voidâ†’"" (no return type). Non-primitives are capitalized via s_pascal to
# match Rust's PascalCase convention for user-defined structs and enums.
fn string render_rust_type(string type_name)
	if type_name is "void"
		return ""
	if type_name is "int"
		return "i32"
	if type_name is "string"
		return "String"
	if type_name is "bool"
		return "bool"
	if type_name is "float"
		return "f64"
	return s_pascal(type_name)
