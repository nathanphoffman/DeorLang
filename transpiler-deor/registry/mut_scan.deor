
# Mutability pre-scan helpers. These run before code generation to determine which
# variables need `let mut` in the generated Rust.

# Finds the DEDENT token that closes the block opened by the INDENT at indent_pos.
# Tracks nesting depth so inner blocks don't terminate the search prematurely.
fn int find_block_end(tokenList tokens, int indent_pos)
	int token_count = len(tokens)
	int depth = 1
	int result = indent_pos
	int start = indent_pos + 1
	for raw_i in (start, token_count)
		Token token = tokens at raw_i
		(kind, value, line) in token
		if kind is "INDENT"
			depth = depth + 1
		else if kind is "DEDENT"
			depth = depth - 1
			if depth is 0
				result = raw_i
				break
	return result

# Finds the DEDENT token that closes the block opened by the INDENT at indent_pos (ref variant).
fn int find_block_end_ref(TokensRef tokens, int indent_pos)
	int token_count = len(tokens)
	int depth = 1
	int result = indent_pos
	int start = indent_pos + 1
	for raw_i in (start, token_count)
		Token token = tokens at raw_i
		(kind, value, line) in token
		if kind is "INDENT"
			depth = depth + 1
		else if kind is "DEDENT"
			depth = depth - 1
			if depth is 0
				result = raw_i
				break
	return result

fn strList collect_mut_names(tokenList tokens, int start, int end_pos)
	strList result = empty
	strList const_names = empty
	for raw_i in (start, end_pos)
		Token token = tokens at raw_i
		(kind, value, line) in token
		if kind is "KW_CONST"
			int const_name_pos = raw_i + 2
			if const_name_pos < end_pos
				Token const_name_tok = tokens at const_name_pos
				(value) in const_name_tok
				if not list_has(const_names, value)
					const_names at end = value
		if kind is "EQUALS"
			int prev_pos = raw_i - 1
			if prev_pos >= start
				Token prev_token = tokens at prev_pos
				(kind, value) in prev_token
				if kind is "IDENT"
					if not list_has(result, value)
						if not list_has(const_names, value)
							result at end = value
	return result
