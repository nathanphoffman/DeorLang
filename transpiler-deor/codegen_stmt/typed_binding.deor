
# Generates code for typed variable declarations: `Type varName = expr`. pos points to
# the type token. Sub-cases dispatched by the kind of the value expression:
#   empty       — Vec::new() for list shapes; error for validators or unknown types
#   (avow x)    — forced unwrap: .unwrap() for custom types, .unwrap().0 for primitives
#   (f1, f2)    — positional struct construction: StructType { f1: v1, f2: v2, ... }
#   [items]     — list literal: let mut varName: RustType = vec![...]
#   bad         — Option<T> None (validator types only)
#   validator   — ValidatorType::new(expr) wrapped in Option<ValidatorType>
#   default     — let [mut] varName: RustType = val[.clone()/.to_string()]
fn ParseResult gen_typed_binding(int pos, int depth, RcCtx ctx)
	(tokens, struct_reg, shape_reg, type_reg, mut_names, variant_reg) in ctx
	int token_count = len(tokens)
	string indent = "    "
	string pad = s_repeat(indent, depth)
	Token type_token = tokens at pos
	(value) in type_token
	string var_type = value
	int name_pos = pos + 1
	Token name_token = tokens at name_pos
	(value) in name_token
	string var_name = value
	int eq_pos = name_pos + 1
	int val_pos = eq_pos + 1
	string rust_type = resolve_type(var_type, shape_reg, variant_reg)
	Token val_token = tokens at val_pos
	(kind) in val_token

	# empty → Vec::new() for list shapes; error otherwise
	if kind is "KW_EMPTY"
		bool is_validator = reg3_has(type_reg, var_type)
		bool is_shape = reg_has(shape_reg, var_type)
		int val_next_pos = val_pos + 1
		int after_empty = adv_nl_ref(val_next_pos, tokens)
		if is_validator
			string err_msg = "/* error: use 'bad' not 'empty' for validator types */\n"
			string err_code = s_join([pad, err_msg])
			return make_result(move err_code, after_empty)
		if is_shape
			string sh_pfx = "let mut "
			string sh_mid = ": "
			string sh_sfx = " = Vec::new();\n"
			string sh_code = s_join([pad, sh_pfx, var_name, sh_mid, rust_type, sh_sfx])
			return make_result(move sh_code, after_empty)
		string err_msg = "/* error: empty is only valid for list shapes */\n"
		string err_code = s_join([pad, err_msg])
		return make_result(move err_code, after_empty)

	# (avow x) or positional struct construction
	if kind is "LPAREN"
		int peek_pos = val_pos + 1
		Token peek_token = tokens at peek_pos
		(kind) in peek_token
		bool is_avow_expr = kind is "KW_AVOW"
		if not is_avow_expr
			string struct_fields_str = reg_get(struct_reg, var_type)
			string comma = ","
			strList field_names = s_split(struct_fields_str, comma)
			strList field_pairs = empty
			int fend = val_pos + 1
			int fni = 0
			int fn_count = len(field_names)
			for if fend < token_count
				Token field_tok = tokens at fend
				(kind) in field_tok
				if kind is "RPAREN"
					fend = fend + 1
					break
				if kind is "COMMA"
					fend = fend + 1
					continue
				ParseResult fv_r = gen_expr(tokens, fend, ctx)
				move (code, new_pos) in fv_r
				fv_code as code
				if fni < fn_count
					string fname = field_names at fni
					string sfp_sep = ": "
					string sfp_cln = ".clone()"
					field_pairs at end = s_join([fname, sfp_sep, fv_code, sfp_cln])
					fni = fni + 1
				fend = new_pos
			string sep = ", "
			string fields_code = s_join_with(field_pairs, sep)
			bool is_mut = list_has(mut_names, var_name)
			string mut_kw = ""
			if is_mut
				mut_kw = "mut "
			string scc_let = "let "
			string scc_eq = " = "
			string scc_ob = " { "
			string scc_cb = " };\n"
			string sc_code = s_join([pad, scc_let, mut_kw, var_name, scc_eq, var_type, scc_ob, fields_code, scc_cb])
			int sc_next = adv_nl_ref(fend, tokens)
			return make_result(move sc_code, sc_next)
		# (avow inner) — .unwrap().0 for primitives, .unwrap() for custom types
		int inner_pos = peek_pos + 1
		ParseResult inner_r = gen_expr(tokens, inner_pos, ctx)
		move (code, new_pos) in inner_r
		inner_code as code
		after_rparen as new_pos + 1
		string suf_unwrap = ".unwrap()"
		string suf_unwrap0 = ".unwrap().0"
		string unwrap_expr = s_cat(inner_code, suf_unwrap)
		if var_type is "int"
			unwrap_expr = s_cat(inner_code, suf_unwrap0)
		if var_type is "string"
			unwrap_expr = s_cat(inner_code, suf_unwrap0)
		if var_type is "bool"
			unwrap_expr = s_cat(inner_code, suf_unwrap0)
		if var_type is "float"
			unwrap_expr = s_cat(inner_code, suf_unwrap0)
		string awc_let = "let "
		string awc_col = ": "
		string awc_eq = " = "
		string awc_sc = ";\n"
		string aw_code = s_join([pad, awc_let, var_name, awc_col, rust_type, awc_eq, unwrap_expr, awc_sc])
		int aw_next = adv_nl_ref(after_rparen, tokens)
		return make_result(move aw_code, aw_next)

	# list literal → always let mut
	if kind is "LBRACKET"
		ParseResult val_r = gen_expr(tokens, val_pos, ctx)
		move (code, new_pos) in val_r
		val_code as code
		val_end as new_pos
		string lst_pfx = "let mut "
		string lst_col = ": "
		string lst_eq = " = "
		string lst_sc = ";\n"
		string lst_code = s_join([pad, lst_pfx, var_name, lst_col, rust_type, lst_eq, val_code, lst_sc])
		int lst_next = adv_nl_ref(val_end, tokens)
		return make_result(move lst_code, lst_next)

	# bad → Option<T> None (validator types only)
	if kind is "KW_BAD"
		bool bad_is_validator = reg3_has(type_reg, var_type)
		int bad_pos_next = val_pos + 1
		int bad_next = adv_nl_ref(bad_pos_next, tokens)
		if bad_is_validator
			string non_pfx = "let mut "
			string non_mid = ": Option<"
			string non_sfx = "> = None;\n"
			string none_code = s_join([pad, non_pfx, var_name, non_mid, rust_type, non_sfx])
			return make_result(move none_code, bad_next)
		string bad_err = "/* error: bad is only valid for validator types */\n"
		string bad_err_code = s_join([pad, bad_err])
		return make_result(move bad_err_code, bad_next)

	# validator type → ValidatorType::new(val) wrapped in Option<>
	bool is_validator = reg3_has(type_reg, var_type)
	if is_validator
		ParseResult val_r = gen_expr(tokens, val_pos, ctx)
		move (code, new_pos) in val_r
		val_code as code
		val_end as new_pos
		bool is_mut = list_has(mut_names, var_name)
		string mut_kw = ""
		if is_mut
			mut_kw = "mut "
		string vld_let = "let "
		string vld_opt = ": Option<"
		string vld_new = "> = "
		string vld_nop = "::new("
		string vld_sc = ");\n"
		string vld_code = s_join([pad, vld_let, mut_kw, var_name, vld_opt, var_type, vld_new, var_type, vld_nop, val_code, vld_sc])
		int vld_next = adv_nl_ref(val_end, tokens)
		return make_result(move vld_code, vld_next)

	# default: let [mut] varName: RustType = val[.clone()/.to_string()];
	ParseResult val_r = gen_expr(tokens, val_pos, ctx)
	move (code, new_pos) in val_r
	val_code as code
	val_end as new_pos
	bool is_mut = list_has(mut_names, var_name)
	string mut_kw = ""
	if is_mut
		mut_kw = "mut "
	string suffix = ""
	if kind is "STRING"
		suffix = ".to_string()"
	else if kind is "IDENT"
		int val_next_idx = val_pos + 1
		if val_next_idx < token_count
			Token next_val_tok = tokens at val_next_idx
			(kind) in next_val_tok
			bool val_is_call = kind is "LPAREN"
			bool val_is_idx = kind is "KW_AT"
			if not val_is_call
				if not val_is_idx
					suffix = ".clone()"
	string bnd_let = "let "
	string bnd_col = ": "
	string bnd_eq = " = "
	string bnd_sc = ";\n"
	string bind_code = s_join([pad, bnd_let, mut_kw, var_name, bnd_col, rust_type, bnd_eq, val_code, suffix, bnd_sc])
	int bind_next = adv_nl_ref(val_end, tokens)
	return make_result(move bind_code, bind_next)
