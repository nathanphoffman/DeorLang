
# Test: raw macro_block_open/close
# Defines Rust functions at top level, with nested raw macro inside raw macro.

raw macro_block_open component
	#[allow(non_snake_case)]
	pub fn TestComponent() -> String {

raw macro_block_close component
	}

raw macro_block_open view_block
	let _view = {

raw macro_block_close view_block
	};
	_view

# Plain Deor macro_block for comparison
macro_block_open section
	rust
		println!("-- begin --");

macro_block_close section
	rust
		println!("-- end --");

# Top-level raw macro_block: defines a Rust function
macro_block component
	let greeting = "hello from raw macro_block";
	macro_block view_block
		format!("view: {}", greeting)

fn void main()
	rust
		let result = TestComponent();
		println!("{}", result);
	macro_block section
		rust
			println!("plain macro_block still works");
