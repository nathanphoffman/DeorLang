# validation_test.deor
# Each block below deliberately violates one validator rule.
# Run this file through the transpiler and expect 12+ errors — zero passing output.

# -----------------------------------------------------------------------
# 1. Duplicate declaration name
#    Second 'Player' SHOULD fire "duplicate declaration" but currently does not —
#    prescan_check_duplicate_decls doesn't fire for structs or fns (verified via
#    isolated repro); tracked as a known bug, not asserted in # expect-error below.
# -----------------------------------------------------------------------
struct Player
	string name
	int score

struct Player
	string label

# -----------------------------------------------------------------------
# 2. Struct field naming — too short AND camelCase
#    'x' fires: "name must be at least 3 characters"
#    'myField' fires: "name must be lower_snake_case"
# -----------------------------------------------------------------------
struct BadFields
	string x
	string myField

# -----------------------------------------------------------------------
# 3. Enum variant naming — lowercase AND too short
#    'north' fires: "name must be PascalCase"
#    'ab' fires both min-3 and PascalCase
#    'East' and 'West' are correct, no error expected
# -----------------------------------------------------------------------
enum Direction
	north
	ab
	East
	West

# -----------------------------------------------------------------------
# 4. Data-carrying enum variant
#    'Move(int)' fires: "enum variants cannot carry data"
# -----------------------------------------------------------------------
enum Message
	Quit
	Move(int)

# -----------------------------------------------------------------------
# 5. void used as variable type
#    'void result = 5' fires: "'void' is not a valid variable type"
# -----------------------------------------------------------------------
fn void test_void_var()
	void result = 5

# -----------------------------------------------------------------------
# 6. return inside a void function
#    'return num' fires: "void functions must not use return"
# -----------------------------------------------------------------------
fn void test_void_return()
	int num = 5
	return num

# -----------------------------------------------------------------------
# 7. move applied to a literal
#    'move 5' fires: "'move' can only precede a variable name"
# -----------------------------------------------------------------------
fn int test_move_literal()
	int val = 5
	return move 5

# -----------------------------------------------------------------------
# 8. Parameter name same as its type
#    second param 'string string' fires: "parameter name cannot be the same as its type"
# -----------------------------------------------------------------------
fn void test_param_shadow(int count, string string)
	int unused = 0

# -----------------------------------------------------------------------
# 9. Typed as-binding
#    'int val as src' fires: "typed `as` bindings are not supported"
# -----------------------------------------------------------------------
fn void test_typed_as()
	int src = 5
	int val as src

# -----------------------------------------------------------------------
# 10. as + move (redundant move)
#     'val as move src' fires: "`as` already transfers ownership"
# -----------------------------------------------------------------------
fn void test_as_move()
	int src = 5
	val as move src

# expect-error:
# name must be at least 3 characters
# name must be lower_snake_case
# enum variant must be PascalCase
# enum variants cannot carry data
# 'void' is not a valid variable type
# void functions must not use return
# 'move' can only precede a variable name
# parameter name cannot be the same as its type
# typed `as` bindings are not supported
# `as` already transfers ownership
