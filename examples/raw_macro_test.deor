
raw macro_block_open component $name
	#[component]
	pub fn $name() -> impl IntoView {

raw macro_block_close component
	}

raw macro_block_open view_block
	view! {

raw macro_block_close view_block
	}

macro_block component App
	macro_block view_block
		<h1>Hello</h1>

macro_block component Counter
	let count = 0;
	macro_block view_block
		<p>{count}</p>

fn void main()
	rust
		println!("transpiled ok");
