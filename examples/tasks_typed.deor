
import "lib/tasks.deor" where T = Report

struct Report
	string title
	int score

fn void make_report(ReportSender snd)
	string title = "analysis complete"
	int score = 42
	Report rep as (title, score)
	t_report_chan_send(snd, rep)

fn void main()
	macro_run task_runner

	t_report_spawn(pool, snd, make_report)

	Report result = t_report_chan_recv(rcv)
	(title, score) in result
	print(title)
	print(score)
