import "lib/convert.deor"

enum string Color
    Red = "Red"
    Green = "Green"
    Blue = "Blue"

enum int Priority
    Low = 1
    Medium = 2
    High = 3

fn void main()
    (Red) in Color
    print(Red)

    (Green, Blue) in Color
    print(Green)
    print(Blue)

    (Low, High) in Priority
    int range = High - Low
    string range_str = c_int_to_string(range)
    print(range_str)
