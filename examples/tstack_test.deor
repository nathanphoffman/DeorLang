import "lib/tstack.deor" where T = Employee
import "lib/tstack.deor" where T = Invoice

struct Employee
	string name
	int age

struct Invoice
	string ref_num
	int amount

fn void main()
	employeeStack emp_stack = t_employee_make()

	string name = "Alice"
	int age = 30
	Employee alice as (name, age)
	emp_stack at end = alice

	string name = "Bob"
	int age = 25
	Employee bob as (name, age)
	emp_stack at end = bob

	int emp_count = t_employee_size(emp_stack)
	print(emp_count)

	int first_idx = 0
	Employee first_emp = t_employee_get(emp_stack, first_idx)
	(name) in first_emp
	print(name)

	invoiceStack inv_stack = t_invoice_make()

	string ref_num = "INV-001"
	int amount = 500
	Invoice inv as (ref_num, amount)
	inv_stack at end = inv

	int inv_count = t_invoice_size(inv_stack)
	print(inv_count)
